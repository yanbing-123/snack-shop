# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/ticket_system
DATABASE_ASYNC_URL=postgresql+asyncpg://user:password@localhost:5432/ticket_system

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 加密密钥 (用于加密敏感数据)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# 12306 账号配置 (示例，实际使用时通过 API 添加)
RAILWAY_USERNAME=
RAILWAY_PASSWORD=

# 通知服务配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-smtp-password
NOTIFICATION_EMAIL=your-email@qq.com

# 短信服务配置 (阿里云)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_PHONE_NUMBER=

# 打码平台配置 (可选)
CAPTCHA_PLATFORM=
CAPTCHA_API_KEY=

# 系统配置
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=True

# 频率限制 (防封号)
QUERY_INTERVAL_SECONDS=3
MONITOR_MIN_INTERVAL_SECONDS=30
MAX_RETRY_ATTEMPTS=3
